.page-container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 120rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-avatar {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999999;
  font-weight: bold;
}

.empty-sub {
  font-size: 26rpx;
  color: #CCCCCC;
  margin-top: 8rpx;
}

.go-btn {
  margin-top: 32rpx;
  background: #6A5ACD;
  color: #FFFFFF;
  border-radius: 50rpx;
  padding: 16rpx 60rpx;
  font-size: 28rpx;
  font-weight: bold;
}

/* 区域标题 */
.section-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 24rpx 28rpx 12rpx;
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.section-icon {
  font-size: 32rpx;
}

/* 收藏列表 */
.fav-list {
  padding: 0 20rpx;
}

.fav-item {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.fav-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFE4EC, #FFC0CB);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  border: 2rpx solid #FFB6C1;
}

.fav-info {
  flex: 1;
  overflow: hidden;
}

.fav-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 6rpx;
}

.fav-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.fav-stars {
  display: flex;
  align-items: center;
  gap: 2rpx;
}

.star {
  color: #FFD700;
  font-size: 20rpx;
}

.fav-rating {
  color: #FFD700;
  font-size: 22rpx;
  font-weight: bold;
  margin-left: 4rpx;
}

.fav-sales {
  font-size: 22rpx;
  color: #999999;
}

.fav-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #6A5ACD;
  display: block;
}

.fav-remove {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FF4757;
  font-size: 28rpx;
  font-weight: bold;
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* 添加按钮 */
.add-btn-wrap {
  position: fixed;
  bottom: 40rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
}

.add-btn {
  background: #6A5ACD;
  color: #FFFFFF;
  border-radius: 50rpx;
  padding: 20rpx 60rpx;
  font-size: 30rpx;
  font-weight: bold;
  box-shadow: 0 6rpx 16rpx rgba(106, 90, 205, 0.3);
}

.add-btn:active {
  opacity: 0.85;
}
