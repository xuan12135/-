.page-container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 120rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFE4EC, #FFC0CB);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  margin-bottom: 24rpx;
  border: 3rpx solid #FFB6C1;
}

.empty-text {
  font-size: 32rpx;
  color: #333333;
  font-weight: bold;
}

.empty-sub {
  font-size: 26rpx;
  color: #999999;
  margin-top: 12rpx;
}

.go-btn {
  margin-top: 40rpx;
  background: linear-gradient(135deg, #9B7FD4, #6A5ACD);
  color: #FFFFFF;
  border-radius: 50rpx;
  padding: 16rpx 56rpx;
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 6rpx 16rpx rgba(106, 90, 205, 0.25);
}

/* 订单列表 */
.order-list {
  padding: 16rpx 20rpx;
}

.section-title {
  display: flex;
  align-items: center;
  padding: 16rpx 8rpx;
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.section-icon {
  margin-right: 8rpx;
  font-size: 32rpx;
}

/* 订单卡片 */
.order-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.order-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.order-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFE4EC, #FFC0CB);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 16rpx;
  border: 2rpx solid #FFB6C1;
}

.order-basic {
  display: flex;
  flex-direction: column;
}

.order-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.order-id {
  font-size: 22rpx;
  color: #999999;
  margin-top: 4rpx;
}

.order-status {
  font-size: 24rpx;
  font-weight: bold;
  padding: 6rpx 20rpx;
  border-radius: 50rpx;
}

.order-status.pending {
  background: rgba(106, 90, 205, 0.1);
  color: #6A5ACD;
}

.order-status.making {
  background: rgba(255, 165, 0, 0.1);
  color: #FFA500;
}

.order-status.done {
  background: rgba(76, 175, 80, 0.1);
  color: #4CAF50;
}

.order-specs {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin: 16rpx 0 16rpx 96rpx;
}

.spec-chip {
  background: #F5F5F5;
  color: #666666;
  border-radius: 6rpx;
  padding: 0 12rpx;
  font-size: 22rpx;
  height: 32rpx;
  line-height: 32rpx;
  display: inline-block;
  vertical-align: middle;
}

.order-bottom {
  display: flex;
  align-items: center;
  padding-left: 96rpx;
  gap: 16rpx;
}

.order-price-wrap {
  flex: 1;
}

.order-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #6A5ACD;
}

.order-time {
  font-size: 22rpx;
  color: #BBBBBB;
  flex: 2;
}

.delete-btn {
  color: #FF4757;
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border: 2rpx solid #FF4757;
  border-radius: 50rpx;
}

.delete-btn:active {
  background: #FF4757;
  color: #FFFFFF;
}
