var formatTime = function(ts) {
  var d = getDate(ts)
  var year = d.getFullYear()
  var month = d.getMonth() + 1
  var day = d.getDate()
  var hour = d.getHours()
  var minute = d.getMinutes()
  var second = d.getSeconds()

  var pad = function(n) {
    n = n.toString()
    return n[1] ? n : '0' + n
  }

  return year + '-' + pad(month) + '-' + pad(day) + ' ' + pad(hour) + ':' + pad(minute) + ':' + pad(second)
}

module.exports = {
  formatTime: formatTime
}
